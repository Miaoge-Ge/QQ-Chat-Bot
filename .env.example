# OneBot 监听配置
ONEBOT_MODE=ws
ONEBOT_WS_URL=ws://127.0.0.1:3001
ONEBOT_ACCESS_TOKEN=

# 主 LLM 配置 (OpenAI 兼容)
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 图像理解 (VL) 模型配置 - 独立配置
VL_BASE_URL=http://127.0.0.1:8000/v1
VL_API_KEY=
VL_MODEL_NAME=gpt-4o-mini

# 图像识别 (OCR) 模型配置 - 独立配置
OCR_BASE_URL=http://127.0.0.1:8000/v1
OCR_API_KEY=
OCR_MODEL_NAME=gpt-4o-mini

# 图像生成配置
IMAGE_GENERATE_BASE_URL=http://127.0.0.1:8000/v1
IMAGE_GENERATE_API_KEY=
IMAGE_GENERATE_MODEL_NAME=dall-e-3

# 其他设置
GROUP_REPLY_MODE=mention
REPLY_AT_SENDER=true
WEB_SEARCH_ENABLED=true

# 管理员 QQ（多个用逗号分隔）
ADMIN_QQ_IDS=123456,234567
